# ─────────────────────────────────────────────────────────────
# Palmas Mall — variables de entorno
# Copia este archivo a .env (desarrollo) o configúralas en Railway (producción)
# ─────────────────────────────────────────────────────────────

# PostgreSQL. En Railway: usa la variable referenciada ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/palmasmall"

# Auth.js / NextAuth. Genera un secreto con: openssl rand -base64 32
AUTH_SECRET=""
# URL pública de la app (en Railway: https://<tu-app>.up.railway.app o tu dominio)
NEXTAUTH_URL="https://palmasmall.com"
AUTH_TRUST_HOST="true"

# URL canónica del sitio público (usada para sitemap, canonicals, JSON-LD y OG)
PUBLIC_SITE_URL="https://palmasmall.com"

# Credenciales del primer usuario SUPER_ADMIN (las usa `prisma db seed`)
ADMIN_EMAIL="admin@palmasmall.com"
ADMIN_PASSWORD="cambia-esta-contraseña"

# Almacenamiento de imágenes subidas desde el admin.
# Recomendado en producción: Cloudinary (Railway no debe guardar media en su filesystem).
# Formato: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=""
# Carpeta dentro de Cloudinary donde se guardan los uploads
CLOUDINARY_FOLDER="palmas-mall"

# Alternativa S3-compatible (si prefieres R2/S3/Supabase Storage, ver README §Storage)
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""

NODE_ENV="production"
